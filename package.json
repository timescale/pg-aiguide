{
  "name": "@tigerdata/pg-aiguide",
  "version": "0.5.1",
  "description": "Comprehensive PostgreSQL documentation and best practices through semantic search and curated skills, including ecosystem tools like TimescaleDB and Tiger Cloud",
  "license": "Apache-2.0",
  "author": "TigerData",
  "homepage": "https://tigerdata.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/timescale/pg-aiguide"
  },
  "mcpName": "io.github.timescale/pg-aiguide",
  "type": "module",
  "bin": {
    "pg-aiguide": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && shx chmod +x dist/*.js",
    "check": "./bun i --silent && ./bun --silent run typecheck && ./bun --silent run lint --write && ./bun --silent run validate-skills && ./bun --silent test --only-failures",
    "inspector": "./bun x @modelcontextprotocol/inspector",
    "lint": "biome check",
    "validate-skills": "./bun scripts/validate-skills.ts",
    "migrate": "migrate",
    "prepublishOnly": "./bun run build",
    "start": "./bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "watch": "./bun --watch src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@tigerdata/mcp-boilerplate": "1.5.0",
    "ai": "7.0.2",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "migrate": "^2.1.0",
    "pg": "^8.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "semver": "^7.8.5",
    "shx": "^0.4.0",
    "typescript": "6.0.3"
  }
}
