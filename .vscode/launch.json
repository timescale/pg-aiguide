{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PostGIS Docs (file, v3.5)",
      "type": "debugpy",
      "request": "launch",
      "module": "ingest.postgis_docs",
      "args": ["--version", "3.5", "--storage-type", "file"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/ingest/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "PostGIS Docs (database, v3.5)",
      "type": "debugpy",
      "request": "launch",
      "module": "ingest.postgis_docs",
      "args": ["--version", "3.5", "--storage-type", "database"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/ingest/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "Postgres Docs",
      "type": "debugpy",
      "request": "launch",
      "module": "ingest.postgres_docs",
      "args": ["17"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/ingest/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "Tiger Docs (file)",
      "type": "debugpy",
      "request": "launch",
      "module": "ingest.tiger_docs",
      "args": ["--storage-type", "file"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/ingest/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "Tiger Docs (database)",
      "type": "debugpy",
      "request": "launch",
      "module": "ingest.tiger_docs",
      "args": ["--storage-type", "database"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/ingest/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "pg-aiguide MCP Server (stdio)",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "pg-aiguide MCP - Build Only",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--enable-source-maps"],
      "program": "${workspaceFolder}/dist/index.js",
      "args": ["stdio"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js", "!**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "pg-aiguide MCP Server (http)",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "pg-aiguide MCP - Build Only",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--enable-source-maps"],
      "program": "${workspaceFolder}/dist/index.js",
      "args": ["http"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js", "!**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
